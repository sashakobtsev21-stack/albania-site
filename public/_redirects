# 301-редиректы Cloudflare (SPEC §7, CLAUDE правило 3).
# URL после индексации не меняются — исправления slug делаются ТОЛЬКО здесь.
# Формат:  /старый-путь/   /новый-путь/   301

# Сайт переведён на ОДИН язык — английский (en) на корне (2026-06-22).
# Прежние языковые URL (/en/, /ru/, /uk/) → 301 на тот же путь на корне.
/en/* /:splat 301
/ru/* /:splat 301
/uk/* /:splat 301
